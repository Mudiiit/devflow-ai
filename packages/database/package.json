{
  "name": "@devflow/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./dist/client/index.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./dist/schema/index.js"
    },
    "./relations": {
      "types": "./src/relations/index.ts",
      "import": "./dist/relations/index.js"
    },
    "./repositories": {
      "types": "./src/repositories/index.ts",
      "import": "./dist/repositories/index.js"
    },
    "./transactions": {
      "types": "./src/transactions/index.ts",
      "import": "./dist/transactions/index.js"
    },
    "./seeds": {
      "types": "./src/seeds/index.ts",
      "import": "./dist/seeds/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "pnpm build && node dist/seeds/index.js",
    "migrate:prod": "pnpm build && node dist/scripts/runMigrations.js"
  },
  "dependencies": {
    "@devflow/config": "workspace:*",
    "@devflow/billing": "workspace:*",
    "@devflow/tracing": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.15.0",
    "drizzle-orm": "^0.39.1",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}