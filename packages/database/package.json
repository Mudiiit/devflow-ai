{
  "name": "@devflow/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./relations": {
      "types": "./dist/relations/index.d.ts",
      "import": "./dist/relations/index.js"
    },
    "./repositories": {
      "types": "./dist/repositories/index.d.ts",
      "import": "./dist/repositories/index.js"
    },
    "./transactions": {
      "types": "./dist/transactions/index.d.ts",
      "import": "./dist/transactions/index.js"
    },
    "./seeds": {
      "types": "./dist/seeds/index.d.ts",
      "import": "./dist/seeds/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "pnpm build && node dist/seeds/index.js"
  },
  "dependencies": {
    "@devflow/config": "workspace:*",
    "drizzle-orm": "^0.39.1",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}