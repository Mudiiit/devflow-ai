{
  "name": "@devflow/ai-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./review": {
      "types": "./src/review/index.ts",
      "import": "./dist/review/index.js"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "import": "./dist/providers/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@devflow/tracing": "workspace:*",
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}