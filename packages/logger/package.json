{
  "name": "@devflow/logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@devflow/database": "workspace:*",
    "@devflow/tracing": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "drizzle-orm": "^0.39.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5"
  }
}