{
  "name": "devflow-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run web:dev --filter=web",
    "dev:api": "turbo run api:dev --filter=api",
    "dev:worker": "turbo run worker:dev --filter=worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:playwright": "playwright test",
    "format": "turbo run format",
    "clean": "turbo run clean && pnpm exec rimraf .turbo node_modules **/dist **/.next **/coverage",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "verify:deployment": "node infra/scripts/verify-deployment.js",
    "validate:env": "node infra/scripts/validate-env.js",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "migrate:prod": "pnpm --filter @devflow/database migrate:prod",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.15.0",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4",
    "typescript": "^5.4.5"
  }
}
