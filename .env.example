# Core
NODE_ENV=production

# PostgreSQL
POSTGRES_DB=devflow
POSTGRES_USER=devflow
POSTGRES_PASSWORD=devflow_password
DATABASE_URL=postgresql://devflow:devflow_password@postgres:5432/devflow

# Redis
REDIS_URL=redis://redis:6379

# Web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
JWT_SECRET=change-me-in-production
SECRET_ENCRYPTION_KEY=change-me-with-32-char-min
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120
API_MAX_BODY_BYTES=1000000
API_IDEMPOTENCY_TTL_SECONDS=86400

# GitHub App / OAuth
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
 
# Observability (optional)
SENTRY_DSN=
OTEL_COLLECTOR_URL=

# Public metadata (used in UI and meta tags)
NEXT_PUBLIC_APP_NAME=DevFlow AI
NEXT_PUBLIC_GITHUB_REPO=
